        {
            "name": "Run menu-example (Linux, GNUstep)",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "exec bash -lc 'XAUTH=${XAUTHORITY:-$HOME/.Xauthority}; exec docker run --rm -e DISPLAY=$DISPLAY -e XAUTHORITY=/tmp/.Xauthority -v \"$XAUTH\":/tmp/.Xauthority:ro -v /tmp/.X11-unix:/tmp/.X11-unix -v \"${workspaceFolder}\":/src -w /src/build/linux-gnustep/examples/03_menu_example wischner/gcc-x86_64-linux-gnustep ./menu-example'",
            "preLaunchTask": "CMake Build (Docker GNUstep)"
        },
        {
            "name": "Run painter (Linux, GNUstep)",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "exec bash -lc 'XAUTH=${XAUTHORITY:-$HOME/.Xauthority}; exec docker run --rm -e DISPLAY=$DISPLAY -e XAUTHORITY=/tmp/.Xauthority -v \"$XAUTH\":/tmp/.Xauthority:ro -v /tmp/.X11-unix:/tmp/.X11-unix -v \"${workspaceFolder}\":/src -w /src/build/linux-gnustep/examples/02_painter_example wischner/gcc-x86_64-linux-gnustep ./painter-example'",
