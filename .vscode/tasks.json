      {
          "label": "Run app-example (macOS leia)",
          "type": "shell",
          "command": "bash",
          "args": ["${workspaceFolder}/tools/macos-remote/run.sh", "app"],
          "problemMatcher": [],
          "dependsOn": ["Build (macOS leia)"],
          "presentation": {
              "reveal": "always",
