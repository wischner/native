{
  "version": "2.0.0",
  "tasks": [
      // Linux Docker-backed CMake targets
      {
          "label": "CMake Configure (Docker Targets)",
          "type": "shell",
          "command": "cmake",
          "args": ["-S", ".", "-B", "out", "-G", "Unix Makefiles", "-DCMAKE_BUILD_TYPE=Debug"],
          "problemMatcher": [],
          "group": "build",
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker X11)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-x11"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker SDL2)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-sdl2"],
          "problemMatcher": "$gcc",
          "group": { "kind": "build", "isDefault": true },
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker OpenMotif)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-openmotif"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker GNUstep)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-gnustep"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker Win)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-win"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },

      // Remote runtime: OpenMotif on CDE machine (charlie)
      {
          "label": "Sync source (OpenMotif charlie)",
          "type": "shell",
          "command": "bash",
          "args": [
              "-lc",
              "set -e; rsync -az --delete --exclude .git --exclude build --exclude out --exclude .claude \"$PWD/\" tomaz@charlie:~/Projects/${workspaceFolderBasename}/"
          ],
          "problemMatcher": [],
          "os": { "linux": true }
      },
      {
          "label": "Build native (OpenMotif charlie)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "tomaz@charlie",
              "set -e; ROOT=\"$HOME/Projects/${workspaceFolderBasename}\"; cd \"$ROOT\"; cmake -S . -B build/tribblix-openmotif -G \"Unix Makefiles\" -DCMAKE_BUILD_TYPE=Debug -DTOOLKIT=MOTIF; cmake --build build/tribblix-openmotif -j$(getconf NPROCESSORS_ONLN 2>/dev/null || echo 2)"
          ],
          "problemMatcher": "$gcc",
          "dependsOn": ["Sync source (OpenMotif charlie)"],
          "os": { "linux": true }
      },
      {
          "label": "Deploy menu-example (OpenMotif charlie)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "tomaz@charlie",
              "set -e; ROOT=\"$HOME/Projects/${workspaceFolderBasename}\"; mkdir -p \"$ROOT/run\"; cp \"$ROOT/build/tribblix-openmotif/examples/03_menu_example/menu-example\" \"$ROOT/run/menu-example\""
          ],
          "problemMatcher": [],
          "dependsOn": ["Build native (OpenMotif charlie)"],
          "os": { "linux": true }
      },
      {
          "label": "Deploy painter (OpenMotif charlie)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "tomaz@charlie",
              "set -e; ROOT=\"$HOME/Projects/${workspaceFolderBasename}\"; mkdir -p \"$ROOT/run\"; cp \"$ROOT/build/tribblix-openmotif/examples/02_painter_example/painter-example\" \"$ROOT/run/painter-example\""
          ],
          "problemMatcher": [],
          "dependsOn": ["Build native (OpenMotif charlie)"],
          "os": { "linux": true }
      },
      {
          "label": "Deploy app-example (OpenMotif charlie)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "tomaz@charlie",
              "set -e; ROOT=\"$HOME/Projects/${workspaceFolderBasename}\"; mkdir -p \"$ROOT/run\"; cp \"$ROOT/build/tribblix-openmotif/examples/01_app_example/app-example\" \"$ROOT/run/app-example\""
          ],
          "problemMatcher": [],
          "dependsOn": ["Build native (OpenMotif charlie)"],
          "os": { "linux": true }
      },
      {
          "label": "Run menu-example (OpenMotif charlie)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "-tt",
              "tomaz@charlie",
              "cd \"$HOME/Projects/${workspaceFolderBasename}/run\" && export DISPLAY=${DISPLAY:-:0} && ./menu-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["Deploy menu-example (OpenMotif charlie)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Run painter (OpenMotif charlie)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "-tt",
              "tomaz@charlie",
              "cd \"$HOME/Projects/${workspaceFolderBasename}/run\" && export DISPLAY=${DISPLAY:-:0} && ./painter-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["Deploy painter (OpenMotif charlie)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Run app-example (OpenMotif charlie)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "-tt",
              "tomaz@charlie",
              "cd \"$HOME/Projects/${workspaceFolderBasename}/run\" && export DISPLAY=${DISPLAY:-:0} && ./app-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["Deploy app-example (OpenMotif charlie)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },

