{
  "version": "2.0.0",
  "tasks": [
      // Linux Docker-backed CMake targets
      {
          "label": "CMake Configure (Docker Targets)",
          "type": "shell",
          "command": "cmake",
          "args": ["-S", ".", "-B", "out", "-G", "Unix Makefiles", "-DCMAKE_BUILD_TYPE=Debug"],
          "problemMatcher": [],
          "group": "build",
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker X11)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-x11"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker SDL2)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-sdl2"],
          "problemMatcher": "$gcc",
          "group": { "kind": "build", "isDefault": true },
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker OpenMotif)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-openmotif"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker OpenLook)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-openlook"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker GNUstep)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-gnustep"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "CMake Build (Docker Win)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-win"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "Run painter (Windows via Wine)",
          "type": "shell",
          "command": "wine",
          "args": [
              "${workspaceFolder}/build/windows-mingw-w64/examples/02_painter_example/painter-example.exe"
          ],
          "problemMatcher": [],
          "dependsOn": ["Prepare painter runtime (Wine DLLs)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Run app-example (Windows via Wine)",
          "type": "shell",
          "command": "wine",
          "args": [
              "${workspaceFolder}/build/windows-mingw-w64/examples/01_app_example/app-example.exe"
          ],
          "problemMatcher": [],
          "dependsOn": ["Prepare app runtime (Wine DLLs)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Prepare painter runtime (Wine DLLs)",
          "type": "shell",
          "command": "bash",
          "args": [
              "-lc",
              "docker run --rm -u $(id -u):$(id -g) -v \"$PWD\":/src -w /src wischner/gcc-x86_64-windows-mingw-w64 cp -f /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libgcc_s_seh-1.dll /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libstdc++-6.dll /usr/x86_64-w64-mingw32/lib/libwinpthread-1.dll build/windows-mingw-w64/examples/02_painter_example/"
          ],
          "problemMatcher": [],
          "dependsOn": ["CMake Build (Docker Win)"],
          "os": { "linux": true }
      },
      {
          "label": "Prepare app runtime (Wine DLLs)",
          "type": "shell",
          "command": "bash",
          "args": [
              "-lc",
              "docker run --rm -u $(id -u):$(id -g) -v \"$PWD\":/src -w /src wischner/gcc-x86_64-windows-mingw-w64 cp -f /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libgcc_s_seh-1.dll /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libstdc++-6.dll /usr/x86_64-w64-mingw32/lib/libwinpthread-1.dll build/windows-mingw-w64/examples/01_app_example/"
          ],
          "problemMatcher": [],
          "dependsOn": ["CMake Build (Docker Win)"],
          "os": { "linux": true }
      },

      // Haiku
      {
          "label": "CMake Build (Docker Haiku)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-haiku"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "Prepare Haiku run dir",
          "type": "shell",
          "command": "ssh",
          "args": [
              "user@192.168.122.90",
              "mkdir -p /boot/home/Projects/${workspaceFolderBasename}/run"
          ],
          "problemMatcher": [],
          "os": { "linux": true }
      },
      {
          "label": "Deploy app-example to Haiku",
          "type": "shell",
          "command": "scp",
          "args": [
              "${workspaceFolder}/build/haiku/examples/01_app_example/app-example",
              "user@192.168.122.90:/boot/home/Projects/${workspaceFolderBasename}/run/app-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["CMake Build (Docker Haiku)", "Prepare Haiku run dir"],
          "os": { "linux": true }
      },
      {
          "label": "Deploy painter to Haiku",
          "type": "shell",
          "command": "scp",
          "args": [
              "${workspaceFolder}/build/haiku/examples/02_painter_example/painter-example",
              "user@192.168.122.90:/boot/home/Projects/${workspaceFolderBasename}/run/painter-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["CMake Build (Docker Haiku)", "Prepare Haiku run dir"],
          "os": { "linux": true }
      },
      {
          "label": "Run app-example (Haiku)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "user@192.168.122.90",
              "cd /boot/home/Projects/${workspaceFolderBasename}/run && ./app-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["Deploy app-example to Haiku"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Run painter (Haiku)",
          "type": "shell",
          "command": "ssh",
          "args": [
              "user@192.168.122.90",
              "cd /boot/home/Projects/${workspaceFolderBasename}/run && ./painter-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["Deploy painter to Haiku"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },

      {
        "label": "Sync to macOS (rsync)",
        "type": "shell",
        "command": "rsync",
        "args": [
            "-avz",
            "-e", "ssh -T -o 'RemoteCommand=none' -o 'RequestTTY=no'",
            "${workspaceFolder}/",
            "tomaz@vader.local:/Users/tomaz/Projects/${workspaceFolderBasename}/"
        ],
        "problemMatcher": [],
        "group": {
            "kind": "build",
            "isDefault": false
        }
    },
    {
        "label": "CMake Configure (macOS)",
        "type": "shell",
        "command": "ssh",
        "args": [
            "tomaz@vader.local",
            "cd /Users/tomaz/Projects/${workspaceFolderBasename}/ && /usr/local/bin/cmake -B build -G \"Unix Makefiles\" -DCMAKE_BUILD_TYPE=Debug"
        ],
        "problemMatcher": [],
        "dependsOn": ["Sync to macOS (rsync)"]
    },
    {
        "label": "Build (macOS)",
        "type": "process",
        "command": "bash",
        "args": [
            "-c",
            "ssh tomaz@vader.local 'cd /Users/tomaz/Projects/${workspaceFolderBasename}/build && make -j4' | sed 's|/Users/tomaz/Projects/${workspaceFolderBasename}|${workspaceFolder}|g'; exit ${PIPESTATUS[0]}"
        ],
        "group": {
            "kind": "build",
            "isDefault": true
        },
        "problemMatcher": "$gcc",
        "dependsOn": ["CMake Configure (macOS)"]
    }    
      
  ]
}
