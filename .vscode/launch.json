{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run painter (Linux, SDL2)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux-sdl2/examples/02_painter_example/painter-example",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "CMake Build (Docker SDL2)",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
