      },
      {
          "label": "Prepare painter runtime (Wine DLLs)",
          "type": "shell",
          "command": "bash",
          "args": [
              "-lc",
              "docker run --rm -u $(id -u):$(id -g) -v \"$PWD\":/src -w /src wischner/gcc-x86_64-windows-mingw-w64 cp -f /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libgcc_s_seh-1.dll /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libstdc++-6.dll /usr/x86_64-w64-mingw32/lib/libwinpthread-1.dll build/windows-mingw-w64/examples/02_painter_example/"
          ],
          "problemMatcher": [],
          "dependsOn": ["CMake Build (Docker Win)"],
          "os": { "linux": true }
      },
      {
          "label": "Prepare menu runtime (Wine DLLs)",
          "type": "shell",
          "command": "bash",
          "args": [
              "-lc",
              "docker run --rm -u $(id -u):$(id -g) -v \"$PWD\":/src -w /src wischner/gcc-x86_64-windows-mingw-w64 cp -f /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libgcc_s_seh-1.dll /usr/lib/gcc/x86_64-w64-mingw32/10-posix/libstdc++-6.dll /usr/x86_64-w64-mingw32/lib/libwinpthread-1.dll build/windows-mingw-w64/examples/03_menu_example/"
