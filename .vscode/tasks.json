      // Haiku
      {
          "label": "CMake Build (Docker Haiku)",
          "type": "shell",
          "command": "cmake",
          "args": ["--build", "out", "--target", "docker-haiku"],
          "problemMatcher": "$gcc",
          "group": "build",
          "dependsOn": ["CMake Configure (Docker Targets)"],
          "os": { "linux": true }
      },
      {
          "label": "Prepare Haiku run dir",
          "type": "shell",
          "command": "ssh",
          "args": [
              "user@192.168.122.90",
              "mkdir -p /boot/home/Projects/${workspaceFolderBasename}/run"
          ],
          "problemMatcher": [],
          "os": { "linux": true }
      },
      {
          "label": "Deploy menu-example to Haiku",
          "type": "shell",
          "command": "scp",
          "args": [
              "${workspaceFolder}/build/haiku/examples/03_menu_example/menu-example",
              "user@192.168.122.90:/boot/home/Projects/${workspaceFolderBasename}/run/menu-example"
          ],
          "problemMatcher": [],
          "dependsOn": ["CMake Build (Docker Haiku)", "Prepare Haiku run dir"],
          "os": { "linux": true }
      },
      {
          "label": "Deploy painter to Haiku",
          "type": "shell",
