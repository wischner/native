          },
          "os": { "linux": true }
      },
      {
          "label": "Run painter (macOS leia)",
          "type": "shell",
          "command": "bash",
          "args": ["${workspaceFolder}/tools/macos-remote/run.sh", "painter"],
          "problemMatcher": [],
          "dependsOn": ["Build (macOS leia)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Debug app-example (macOS leia, LLDB)",
          "type": "shell",
          "command": "bash",
          "args": ["${workspaceFolder}/tools/macos-remote/debug.sh", "app"],
          "problemMatcher": [],
          "dependsOn": ["Build (macOS leia)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Debug painter (macOS leia, LLDB)",
          "type": "shell",
          "command": "bash",
          "args": ["${workspaceFolder}/tools/macos-remote/debug.sh", "painter"],
          "problemMatcher": [],
          "dependsOn": ["Build (macOS leia)"],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      },
      {
          "label": "Smoke Test (macOS leia, no quarantine)",
          "type": "shell",
          "command": "bash",
          "args": ["${workspaceFolder}/tools/macos-remote/smoke-test.sh"],
          "problemMatcher": [],
          "presentation": {
              "reveal": "always",
              "panel": "shared"
          },
          "os": { "linux": true }
      }
      
  ]
}
